{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Universal Agent Plugin Manifest",
  "type": "object",
  "properties": {
    "name": { "type": "string" },
    "description": { "type": "string" },
    "version": { "type": "string" },
    "author": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" }
      }
    },
    "source": { "oneOf": [{ "type": "string" }, { "type": "object" }] },
    "category": { "type": "string" }
  },
  "required": ["name", "description"]
}
